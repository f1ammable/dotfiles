{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "final_space": true,
  "version": 2,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "time",
          "style": "plain",
          "foreground": "#FB4934",
          "template": "{{ .CurrentDate | date .Format }}",
          "properties": {
            "time_format": "15:04:05"
          }
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "#8EC07C",
          "properties": {
            "style": "mixed",
            "mixed_threshold": 8
          }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#FABD2F",
          "template": "{{ .HEAD}} "
        },
        {
          "type": "cmake",
          "style": "plain",
          "foreground": "#83A598",
          "template": "\ue61e {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} "
        }
      ]
    },
    {
      "alignment": "left",
      "newline": true,
      "type": "prompt",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "template": "\uea9f",
          "foreground": "#EDBBB2"
        }
      ]
    }
  ]
}
