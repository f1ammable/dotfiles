{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "final_space": true,
  "version": 2,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "plain",
          "foreground": "#FB4934",
          "template": "{{ if .WSL}}[WSL] {{ end }}{{.Icon}}",
          "properties": {
            "macos": "osx",
            "windows": "win",
            "ubuntu": "ubuntu"
          }
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "#8EC07C",
          "properties": {
            "style": "full"
          }
        },
        {
          "type": "text",
          "style": "plain",
          "template": "\uF101",
          "foreground": "#EDBBB2"
        }
      ]
    },
    {
      "type": "rprompt",
      "alignment": "right",
      "segments": [
        {
          "type": "git",
          "style": "plain",
          "foreground": "#FABD2F",
          "template": "git:({{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uF044 {{ .Working.String }}{{ end }}{{ if and (.Staging.Changed) (.Working.Changed) }} {{ end }}{{ if .Staging.Changed }} \uF046 {{ .Staging.String }}{{ end }}) ",
          "properties": {
            "branch_max_length": 25,
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "branch_icon": ""
          }
        },
        {
          "type": "cmake",
          "style": "plain",
          "foreground": "#83A598",
          "template": "\ue61e {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} "
        },
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "#D3869B",
          "template": "{{ .FormattedMs }} ",
          "properties": {
            "style": "austin"
          }
        }
      ]
    }
  ]
}
