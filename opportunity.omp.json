{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "final_space": true,
  "version": 2,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "plain",
          "foreground": "#FB4934"
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "#B8BB26",
          "properties": {
            "style": "full"
          }
        },
        {
          "type": "text",
          "style": "plain",
          "template": "\uEA9F",
          "foreground": "#EDBBB2"
        }
      ]
    },
    {
      "type": "rprompt",
      "alignment": "right",
      "segments": [
        {
          "type": "git",
          "style": "plain",
          "foreground": "#FABD2F",
          "template": "{{ .UpstreamIcon }}{{ .HEAD }}{{ if gt .StashCount 0 }} \uf692 {{ .StashCount }}{{ end }} ",
          "properties": {
            "branch_max_length": 25,
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "branch_icon": ""
          }
        },
        {
          "type": "cmake",
          "style": "plain",
          "foreground": "#83A598",
          "template": "\ue61e {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}"
        },
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "#D3869B",
          "template": "{{ .FormattedMs }}",
          "properties": {
            "style": "austin"
          }
        }
      ]
    }
  ]
}
